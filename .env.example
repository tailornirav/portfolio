# ============================================================================
#  Server-side secrets  (NEVER commit real values — .env is gitignored)
#  Set these in the Vercel dashboard under Project → Settings → Environment
#  Variables for production deployments.
# ============================================================================

# --- Email delivery (Resend) ----------------------------------------------
# API key from https://resend.com/api-keys. The /api/testflight endpoint
# uses this to notify CONTACT_NOTIFY_EMAIL whenever someone submits the form.
RESEND_API_KEY=""

# The address that receives TestFlight request notifications.
CONTACT_NOTIFY_EMAIL="me@tailornirav.dev"

# Verified sending identity inside Resend. Must be a domain/address you own
# and have validated in the Resend dashboard.
CONTACT_FROM_EMAIL="portfolio@tailornirav.dev"
